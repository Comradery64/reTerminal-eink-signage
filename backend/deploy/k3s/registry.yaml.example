# ─────────────────────────────────────────────────────────────────────────────
# In-cluster OCI registry for the broker image — for clusters with no external registry.
#
# Why this shape: if your cluster has no external registry and no per-node SSH, `ctr import`
# on every node isn't practical. Instead run registry:2 in-cluster, expose it on a stable
# LoadBalancer IP (MetalLB or your LB of choice), and tell each node's containerd to pull from
# it over plain HTTP via a `hosts.toml` dropped into containerd's certs.d (config_path) dir —
# which k3s/containerd reads LIVE, per-pull, so no k3s restart and no SSH are required.
#
# Replace REGISTRY_LB_IP (placeholder 203.0.113.11, an RFC 5737 documentation address) with a
# real LoadBalancer IP from your own pool before applying.
#
# Push (from a workstation):   kubectl -n registry port-forward svc/registry 5000:5000
#                              docker push localhost:5000/<your-image-repo>:<tag>
#   (docker trusts localhost by default; the cluster pulls the same repo via REGISTRY_LB_IP:5000)
# Pull (in broker.yaml):       image: REGISTRY_LB_IP:5000/<your-image-repo>:<tag>
# ─────────────────────────────────────────────────────────────────────────────
apiVersion: v1
kind: Namespace
metadata:
  name: registry
---
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: registry-data
  namespace: registry
spec:
  accessModes: ["ReadWriteOnce"]
  storageClassName: longhorn      # swap for whatever storage class your cluster provides
  resources:
    requests:
      storage: 20Gi
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: registry
  namespace: registry
spec:
  replicas: 1                     # RWO volume → single writer
  strategy: { type: Recreate }
  selector:
    matchLabels: { app: registry }
  template:
    metadata:
      labels: { app: registry }
    spec:
      securityContext:
        runAsNonRoot: true
        runAsUser: 1000
        fsGroup: 1000
        seccompProfile: { type: RuntimeDefault }
      containers:
        - name: registry
          image: registry:2
          ports: [{ containerPort: 5000 }]
          env:
            - { name: REGISTRY_HTTP_ADDR, value: ":5000" }
            - { name: REGISTRY_STORAGE_DELETE_ENABLED, value: "true" }
          volumeMounts:
            - { name: data, mountPath: /var/lib/registry }
          resources:
            requests: { cpu: "50m", memory: "128Mi" }
            limits:   { cpu: "1",   memory: "512Mi" }
          readinessProbe:
            httpGet: { path: /v2/, port: 5000 }
            initialDelaySeconds: 3
          livenessProbe:
            httpGet: { path: /v2/, port: 5000 }
            periodSeconds: 20
          securityContext:
            allowPrivilegeEscalation: false
            readOnlyRootFilesystem: true
            capabilities: { drop: ["ALL"] }
      volumes:
        - name: data
          persistentVolumeClaim: { claimName: registry-data }
---
apiVersion: v1
kind: Service
metadata:
  name: registry
  namespace: registry
  annotations:
    metallb.io/loadBalancerIPs: "203.0.113.11"   # REPLACE with your own LB IP
spec:
  type: LoadBalancer
  selector: { app: registry }
  ports:
    - port: 5000
      targetPort: 5000
---
# Register the insecure (HTTP) registry with every node's containerd. containerd reads
# config_path (certs.d) dynamically at pull time, so writing this file needs no restart.
# The pod writes once, then idles; on node/pod restart it rewrites (the file is regenerated
# by k3s from registries.yaml only at k3s startup, and we don't use registries.yaml here).
apiVersion: apps/v1
kind: DaemonSet
metadata:
  name: registry-certs-d
  namespace: registry
spec:
  selector:
    matchLabels: { app: registry-certs-d }
  template:
    metadata:
      labels: { app: registry-certs-d }
    spec:
      tolerations:
        - operator: Exists        # tolerate control-plane/etcd taints if your registry runs there
      containers:
        - name: writer
          image: busybox:1.36
          command: ["sh", "-c"]
          args:
            # REPLACE 203.0.113.11 with the same LB IP used above.
            - |
              set -e
              D=/host/var/lib/rancher/k3s/agent/etc/containerd/certs.d/203.0.113.11:5000
              mkdir -p "$D"
              cat > "$D/hosts.toml" <<'TOML'
              server = "http://203.0.113.11:5000"
              [host."http://203.0.113.11:5000"]
                capabilities = ["pull", "resolve"]
              TOML
              echo "wrote $D/hosts.toml"; cat "$D/hosts.toml"
              # keep the pod alive so the file is re-asserted on restart
              while true; do sleep 3600; done
          volumeMounts:
            - { name: containerd-etc, mountPath: /host/var/lib/rancher/k3s/agent/etc/containerd }
          securityContext:
            privileged: true      # hostPath write to node containerd config
      volumes:
        - name: containerd-etc
          hostPath:
            path: /var/lib/rancher/k3s/agent/etc/containerd
            type: Directory
