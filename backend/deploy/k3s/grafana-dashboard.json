{
  "title": "Meeting Displays — Fleet Health",
  "uid": "meeting-displays-fleet",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "editable": true,
  "graphTooltip": 1,
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "1m",
  "tags": ["meeting-displays"],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Fleet summary",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Fleet size",
      "description": "Total devices that have ever reported in.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "targets": [{ "expr": "count(md_last_seen_seconds)", "instant": true, "refId": "A" }],
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } } }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "In a meeting now",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "targets": [{ "expr": "count(md_room_status_info{status=\"in_meeting\"}) OR vector(0)", "instant": true, "refId": "A" }],
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }] } } }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Available now",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "targets": [{ "expr": "count(md_room_status_info{status=\"available\"}) OR vector(0)", "instant": true, "refId": "A" }],
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } } }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Low battery",
      "description": "Below the low_battery_pct alert threshold (config.yaml alerts.low_battery_pct).",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "targets": [{ "expr": "count(md_battery_percent < 45) OR vector(0)", "instant": true, "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] }
        }
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Offline (>1h)",
      "description": "No telemetry report in over an hour (alerts.stale_after).",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "targets": [{ "expr": "count(md_last_seen_seconds > 3600) OR vector(0)", "instant": true, "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] }
        }
      }
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Not repainting (>1h)",
      "description": "Panel hasn't actually refreshed in over an hour — checking in but not repainting is a ghosting/hardware-health smell, not just a schedule quirk.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "targets": [{ "expr": "count(md_last_render_seconds > 3600) OR vector(0)", "instant": true, "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 1 }] }
        }
      }
    },
    {
      "id": 8,
      "type": "row",
      "title": "All devices",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 9,
      "type": "table",
      "title": "Fleet status",
      "description": "One row per device: what it's currently displaying, battery, signal, and staleness — everything a building manager needs at a glance. Sort/filter any column by clicking its header.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 6 },
      "targets": [
        { "expr": "md_room_status_info", "format": "table", "instant": true, "refId": "status" },
        { "expr": "md_battery_percent", "format": "table", "instant": true, "refId": "battery" },
        { "expr": "md_wifi_rssi_dbm", "format": "table", "instant": true, "refId": "signal" },
        { "expr": "md_last_seen_seconds", "format": "table", "instant": true, "refId": "lastseen" },
        { "expr": "md_last_render_seconds", "format": "table", "instant": true, "refId": "lastrender" },
        { "expr": "md_boot_count", "format": "table", "instant": true, "refId": "boots" }
      ],
      "transformations": [
        {
          "id": "joinByField",
          "options": { "byField": "device", "mode": "outer" }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true, "Time 1": true, "Time 2": true, "Time 3": true, "Time 4": true, "Time 5": true,
              "__name__": true, "__name__ 1": true, "__name__ 2": true, "__name__ 3": true, "__name__ 4": true, "__name__ 5": true,
              "job": true, "instance": true, "Value #status": true
            },
            "indexByName": {
              "device": 0, "status": 1,
              "Value #battery": 2, "Value #signal": 3,
              "Value #lastseen": 4, "Value #lastrender": 5, "Value #boots": 6
            },
            "renameByName": {
              "device": "Room",
              "status": "Status",
              "Value #battery": "Battery %",
              "Value #signal": "Signal (dBm)",
              "Value #lastseen": "Last seen (s ago)",
              "Value #lastrender": "Last refresh (s ago)",
              "Value #boots": "Boot count"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "center", "cellOptions": { "type": "auto" } }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Room" },
            "properties": [{ "id": "custom.align", "value": "left" }]
          },
          {
            "matcher": { "id": "byName", "options": "Status" },
            "properties": [
              { "id": "custom.cellOptions", "value": { "type": "color-background" } },
              { "id": "mappings", "value": [
                { "type": "value", "options": {
                  "available":     { "text": "Available",     "color": "green" },
                  "starting_soon": { "text": "Starting soon", "color": "orange" },
                  "in_meeting":    { "text": "In a meeting",   "color": "red" }
                } }
              ] }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Battery %" },
            "properties": [
              { "id": "unit", "value": "percent" },
              { "id": "custom.cellOptions", "value": { "type": "color-background" } },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [
                { "color": "red", "value": null }, { "color": "orange", "value": 20 }, { "color": "green", "value": 45 }
              ] } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Signal (dBm)" },
            "properties": [
              { "id": "unit", "value": "dBm" },
              { "id": "custom.cellOptions", "value": { "type": "color-background" } },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [
                { "color": "red", "value": null }, { "color": "orange", "value": -75 }, { "color": "green", "value": -65 }
              ] } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Last seen (s ago)" },
            "properties": [
              { "id": "unit", "value": "s" },
              { "id": "custom.cellOptions", "value": { "type": "color-background" } },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [
                { "color": "green", "value": null }, { "color": "red", "value": 3600 }
              ] } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Last refresh (s ago)" },
            "properties": [
              { "id": "unit", "value": "s" },
              { "id": "custom.cellOptions", "value": { "type": "color-background" } },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [
                { "color": "green", "value": null }, { "color": "orange", "value": 3600 }
              ] } }
            ]
          }
        ]
      }
    }
  ]
}
